---
interface Props {
	name: string;
	initials: string;
	review: string;
	size?: 'small' | 'large';
}

const { name, initials, review, size = 'small' } = Astro.props;
const imageSize = size === 'large' ? 128 : 100;
const cardClasses = size === 'large' ? 'p-6 md:p-8' : 'p-5';
const imageClasses = size === 'large' ? 'w-20 h-20' : 'w-16 h-16';
---

<div class:list={[
	"bg-stone-50 rounded-3xl shadow-lg border border-stone-200 flex flex-col items-center text-center hover:shadow-xl transition-shadow duration-300",
	cardClasses
]}>
	<img 
		src={`https://ui-avatars.com/api/?name=${initials}&background=065f46&color=f5f5f4&size=${imageSize}&font-size=0.4&rounded=true`}
		alt={`${name} avatar`}
		class:list={[imageClasses, "rounded-full mb-5 border-2 border-stone-200 shadow-sm"]}
	/>
	<blockquote class="text-stone-600 text-sm md:text-base italic mb-6 leading-relaxed flex-grow">
		"{review}"
	</blockquote>
	<div class="flex items-center justify-center gap-1 mt-auto">
		<svg class="w-4 h-4 text-amber-500" fill="currentColor" viewBox="0 0 20 20">
			<path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
