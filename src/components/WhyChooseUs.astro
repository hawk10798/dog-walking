---
import WhyChooseItem from './WhyChooseItem.astro';
---

<section class="bg-stone-50 p-6 md:p-8 rounded-3xl shadow-lg border border-stone-200">
	<h2 class="text-2xl font-bold text-stone-800 text-center mb-8">Why Choose Happy Paws?</h2>
	<div class="grid grid-cols-1 gap-6">
		<WhyChooseItem>
			<svg slot="icon" class="w-6 h-6 text-stone-100" fill="none" stroke="currentColor" viewBox="0 0 24 24">
				<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
			</svg>
			<span slot="title">Professional Service</span>
			<span slot="description">Trained and experienced dog walkers who understand canine behavior</span>
		</WhyChooseItem>
		<WhyChooseItem>
			<svg slot="icon" class="w-6 h-6 text-stone-100" fill="none" stroke="currentColor" viewBox="0 0 24 24">
				<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
			</svg>
			<span slot="title">Safety First</span>
			<span slot="description">Fully insured and bonded for your peace of mind</span>
		</WhyChooseItem>
		<WhyChooseItem>
			<svg slot="icon" class="w-6 h-6 text-stone-100" fill="none" stroke="currentColor" viewBox="0 0 24 24">
				<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
			</svg>
			<span slot="title">Clear Communication</span>
			<span slot="description">Regular updates and availability to discuss your dog's needs</span>
		</WhyChooseItem>
	</div>
</section>
