---
---

<div class="min-h-screen bg-stone-100 p-5 md:p-10">
	<main class="max-w-6xl mx-auto">
		<div class="text-center mb-8">
			<h1 class="text-4xl md:text-5xl font-bold text-stone-800 mb-4">Contact Us</h1>
		</div>

		<div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-12">
			<div class="bg-stone-50 p-6 md:p-8 rounded-3xl shadow-lg border border-stone-200">
				<h2 class="text-xl font-semibold text-emerald-800 mb-6 pb-3 border-b border-stone-200">Get in Touch</h2>
				
				<div class="mb-6 flex items-start gap-4">
					<div class="w-10 h-10 bg-emerald-800 rounded-xl flex items-center justify-center flex-shrink-0">
						<svg class="w-5 h-5 text-stone-100" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
						</svg>
					</div>
					<div>
						<h3 class="text-lg font-semibold text-stone-700 mb-1">Whatsapp</h3>
						<p class="text-stone-600">
							<a href="tel:+447507269015" class="hover:text-emerald-700 transition-colors">+44 7507 269015</a>
						</p>
					</div>
				</div>

				<div class="mb-6 flex items-start gap-4">
					<div class="w-10 h-10 bg-emerald-800 rounded-xl flex items-center justify-center flex-shrink-0">
						<svg class="w-5 h-5 text-stone-100" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
						</svg>
					</div>
					<div>
						<h3 class="text-lg font-semibold text-stone-700 mb-1">Email</h3>
						<p class="text-stone-600">
							<a href="mailto:info@happypaws.com" class="hover:text-emerald-700 transition-colors">enquiries@happypaws.com</a>
						</p>
					</div>
				</div>

				<div class="flex items-start gap-4">
					<div class="w-10 h-10 bg-amber-700 rounded-xl flex items-center justify-center flex-shrink-0">
						<svg class="w-5 h-5 text-stone-100" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
						</svg>
					</div>
					<div>
						<h3 class="text-lg font-semibold text-stone-700 mb-1">Hours</h3>
						<p class="text-stone-600">
							Monday - Friday: 9:00 AM - 4:30 PM<br />
							Saturday: 10:00 AM - 3:00 PM<br />
							Sunday: Closed
						</p>
					</div>
				</div>
                
                <div class="mt-8">
					<a href="/book" class="inline-block w-full text-center px-10 py-4 bg-emerald-800 text-stone-100 font-semibold rounded-xl hover:bg-emerald-700 transition-all duration-300 shadow-lg hover:shadow-xl">Book a Walk Today</a>
				</div>
			</div>

			<section class="bg-stone-50 p-6 md:p-8 rounded-3xl shadow-lg border border-stone-200">
				<h2 class="text-2xl font-bold text-stone-800 text-center mb-8">Why Choose Happy Paws?</h2>
				<div class="space-y-6">
					<div class="flex items-start gap-4 p-4 bg-stone-100 rounded-xl border border-stone-200">
						<div class="w-12 h-12 bg-emerald-800 rounded-xl flex items-center justify-center flex-shrink-0">
							<svg class="w-6 h-6 text-stone-100" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
							</svg>
						</div>
						<div>
							<h3 class="text-lg font-semibold text-stone-800 mb-1">Professional Service</h3>
							<p class="text-stone-600 text-sm">Trained and experienced dog walkers who understand canine behavior</p>
						</div>
					</div>
					<div class="flex items-start gap-4 p-4 bg-stone-100 rounded-xl border border-stone-200">
						<div class="w-12 h-12 bg-emerald-800 rounded-xl flex items-center justify-center flex-shrink-0">
							<svg class="w-6 h-6 text-stone-100" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
							</svg>
						</div>
						<div>
							<h3 class="text-lg font-semibold text-stone-800 mb-1">Safety First</h3>
							<p class="text-stone-600 text-sm">Fully insured and bonded for your peace of mind</p>
						</div>
					</div>
					<div class="flex items-start gap-4 p-4 bg-stone-100 rounded-xl border border-stone-200">
						<div class="w-12 h-12 bg-amber-700 rounded-xl flex items-center justify-center flex-shrink-0">
							<svg class="w-6 h-6 text-stone-100" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
							</svg>
						</div>
						<div>
							<h3 class="text-lg font-semibold text-stone-800 mb-1">Clear Communication</h3>
							<p class="text-stone-600 text-sm">Regular updates and availability to discuss your dog's needs</p>
						</div>
					</div>
				</div>
			</section>
		</div>
	</main>
</div>
