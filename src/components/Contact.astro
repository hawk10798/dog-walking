---

<div class="min-h-screen bg-stone-100 p-5 md:p-10">
	<main class="max-w-6xl mx-auto">
		<!-- Page Title -->
		<div class="text-center mb-5">
			<h1 class="text-4xl md:text-5xl font-bold text-gray-800 mb-4">Contact Us</h1>
		</div>

		<div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-12">
			<!-- Contact Information -->
			<div class="bg-stone-50 p-6 md:p-8 rounded-2xl shadow-lg">				
				<div class="mb-6">
					<h3 class="text-lg font-semibold text-green-700 mb-2">📞 Whatsapp</h3>
					<p class="text-gray-700">
						<a href="tel:+447507269015" class="hover:text-green-600 transition-colors">+44 7507 269015</a>
					</p>
				</div>

				<div class="mb-6">
					<h3 class="text-lg font-semibold text-green-700 mb-2">📧 Email</h3>
					<p class="text-gray-700">
						<a href="mailto:info@happypaws.com" class="hover:text-green-600 transition-colors">enquiries@happypaws.com</a>
					</p>
				</div>

				<div>
					<h3 class="text-lg font-semibold text-green-700 mb-2">⏰ Hours</h3>
					<p class="text-gray-700">
						Monday - Friday: 9:00 AM - 4:30 PM<br />
						Saturday: 10:00 AM - 3:00 PM<br />
						Sunday: Closed
					</p>
				</div>
                
                <div class="mt-8">
					<a href="/book" class="inline-block w-full text-center px-10 py-4 bg-green-600 text-white font-semibold rounded-lg hover:scale-105 transition-transform duration-300 shadow-lg hover:shadow-xl">Book a Walk Today</a>
				</div>
			</div>

			<!-- Why Choose Us Section -->
			<section class="bg-stone-50 p-6 md:p-8 rounded-2xl shadow-lg">
				<h2 class="text-2xl font-bold text-gray-800 text-center mb-8">Why Choose Happy Paws?</h2>
				<div class="grid grid-cols-1 gap-6">
					<div class="text-center">
						<span class="text-4xl block mb-4">✅</span>
						<h3 class="text-lg font-semibold text-gray-800 mb-2">Professional Service</h3>
						<p class="text-gray-600">Trained and experienced dog walkers who understand canine behavior</p>
					</div>
					<div class="text-center">
						<span class="text-4xl block mb-4">🛡️</span>
						<h3 class="text-lg font-semibold text-gray-800 mb-2">Safety First</h3>
						<p class="text-gray-600">Fully insured and bonded for your peace of mind</p>
					</div>
					<div class="text-center">
						<span class="text-4xl block mb-4">💬</span>
						<h3 class="text-lg font-semibold text-gray-800 mb-2">Clear Communication</h3>
						<p class="text-gray-600">Regular updates and availability to discuss your dog's needs</p>
					</div>
				</div>
			</section>
		</div>
	</main>
</div>
