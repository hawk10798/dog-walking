---
import PricingCard from './PricingCard.astro';
---

<section class="bg-stone-50 p-6 md:p-10 rounded-3xl shadow-lg">
	<h2 class="text-2xl md:text-3xl font-bold text-stone-800 text-center mb-10">Our Prices</h2>
	<div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8">
		<PricingCard 
			title="Single Walk" 
			price="£20" 
			description="One 30-minute walk" 
		/>
		<PricingCard 
			title="5-Walk Package" 
			price="£90" 
			description="£18 per walk (save 10%)" 
			popular={true}
		/>
		<PricingCard 
			title="Daily Service" 
			price="£130" 
			description="Weekday walks" 
		/>
	</div>
</section>
