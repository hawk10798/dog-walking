---
import ContactInfo from './ContactInfo.astro';
import WhyChooseUs from './WhyChooseUs.astro';
---

<div class="bg-stone-100 p-5 md:p-10">
	<main class="max-w-6xl mx-auto">
		<div class="text-center mb-8">
			<h1 class="text-4xl md:text-5xl font-bold text-stone-800 mb-4">Contact Us</h1>
		</div>

		<div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-12">
			<ContactInfo />
			<WhyChooseUs />
		</div>
	</main>
</div>
