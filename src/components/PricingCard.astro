---
interface Props {
	title: string;
	price: string;
	description: string;
	popular?: boolean;
}

const { title, price, description, popular = false } = Astro.props;
---

<div class:list={[
	"p-6 md:p-8 rounded-2xl text-center text-stone-100 shadow-lg transition-all duration-300",
	popular 
		? "bg-gradient-to-br from-amber-700 to-amber-800 border border-amber-600 ring-2 ring-amber-500 shadow-xl scale-105 md:scale-110" 
		: "bg-gradient-to-br from-emerald-800 to-emerald-900 border border-emerald-700 hover:shadow-xl"
]}>
	<h3 class="text-lg md:text-xl font-semibold mb-4">{title}</h3>
	<p class="text-3xl md:text-4xl font-bold mb-4">{price}</p>
	<p class="text-sm md:text-base text-stone-300">{description}</p>
</div>
