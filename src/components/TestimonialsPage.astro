---
import FullTestimonialsGrid from './FullTestimonialsGrid.astro';
---

<div class="text-center mb-10">
	<h1 class="text-4xl md:text-5xl font-bold text-stone-800 mb-4">What Our Clients Say</h1>
	<p class="text-stone-600 text-lg">Don't just take our word for it - hear from our happy customers and their furry friends</p>
</div>

<div class="mb-10">
	<FullTestimonialsGrid />
</div>

<div class="text-center bg-emerald-800 rounded-3xl p-8 shadow-lg">
	<h2 class="text-2xl font-bold text-stone-100 mb-4">Ready to Join the Happy Paws Family?</h2>
	<p class="text-stone-200 mb-6">Your dog deserves the same love and care our clients' dogs receive every day.</p>
	<a href="/book" class="inline-block px-10 py-4 bg-stone-100 text-emerald-800 font-semibold rounded-xl hover:bg-white transition-all duration-300 shadow-lg hover:shadow-xl">
		Book Your First Walk
	</a>
</div>
