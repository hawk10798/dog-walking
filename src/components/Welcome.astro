---
import { Image } from 'astro:assets';
import groupPhoto from '../public/group-photo.jpg';
---

<div class="min-h-screen bg-stone-100 p-5 md:p-10">
	<main class="max-w-7xl mx-auto">
		<section class="bg-stone-50 rounded-3xl shadow-xl mb-12 overflow-hidden">
			<div class="flex flex-col md:flex-row items-center">
				<div class="w-full md:w-1/2">
					<img src="/group-photo.jpg" alt="Happy Paws Team" class="w-full h-auto rounded-t-3xl md:rounded-l-3xl md:rounded-t-none shadow-lg" />
				</div>
				<div class="w-full md:w-1/2 p-6 md:p-10 flex flex-col items-center justify-center">
					<h2 class="text-2xl md:text-3xl font-bold text-stone-800 mb-4 text-center">About Our Team</h2>
					<p class="text-stone-600 text-base md:text-lg leading-relaxed mb-6 text-center">
						At Happy Paws, we're passionate about providing the best care for your beloved pets. Our experienced team members are dedicated to ensuring every dog receives personalized attention, exercise, and socialization. We believe that every walk is an opportunity to create lasting memories and keep your furry friends happy and healthy. With years of combined experience in pet care, we treat each dog like they're part of our own family.
					</p>
					<a href="/book" class="w-full md:w-auto text-center px-10 py-4 bg-emerald-800 text-stone-100 font-semibold rounded-xl hover:bg-emerald-700 transition-all duration-300 shadow-lg hover:shadow-xl hover:-translate-y-0.5">Book a Walk Today</a>
				</div>
			</div>
		</section>
		
		<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 md:gap-6 mb-12">
			<div class="bg-gradient-to-br from-stone-100 to-stone-200 p-6 md:p-8 rounded-3xl shadow-lg hover:shadow-xl hover:-translate-y-1 transition-all duration-300 border border-stone-200">
				<div class="w-14 h-14 bg-emerald-800 rounded-2xl flex items-center justify-center mb-5 shadow-md">
					<svg class="w-7 h-7 text-stone-100" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>
					</svg>
				</div>
				<h3 class="text-lg md:text-xl font-semibold mb-3 text-stone-800">Daily Walks</h3>
				<p class="text-sm md:text-base text-stone-600">Regular 30-minute walks to keep your pup active and healthy</p>
			</div>
			<div class="bg-gradient-to-br from-stone-100 to-stone-200 p-6 md:p-8 rounded-3xl shadow-lg hover:shadow-xl hover:-translate-y-1 transition-all duration-300 border border-stone-200">
				<div class="w-14 h-14 bg-emerald-700 rounded-2xl flex items-center justify-center mb-5 shadow-md">
					<svg class="w-7 h-7 text-stone-100" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
					</svg>
				</div>
				<h3 class="text-lg md:text-xl font-semibold mb-3 text-stone-800">Group Adventures</h3>
				<p class="text-sm md:text-base text-stone-600">Socialization walks with other friendly dogs</p>
			</div>
			<div class="bg-gradient-to-br from-stone-100 to-stone-200 p-6 md:p-8 rounded-3xl shadow-lg hover:shadow-xl hover:-translate-y-1 transition-all duration-300 border border-stone-200">
				<div class="w-14 h-14 bg-amber-700 rounded-2xl flex items-center justify-center mb-5 shadow-md">
					<svg class="w-7 h-7 text-stone-100" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"/>
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"/>
					</svg>
				</div>
				<h3 class="text-lg md:text-xl font-semibold mb-3 text-stone-800">Live Updates</h3>
				<p class="text-sm md:text-base text-stone-600">Photos and GPS updates sent directly to your phone</p>
			</div>
			<div class="bg-gradient-to-br from-stone-100 to-stone-200 p-6 md:p-8 rounded-3xl shadow-lg hover:shadow-xl hover:-translate-y-1 transition-all duration-300 border border-stone-200">
				<div class="w-14 h-14 bg-amber-800 rounded-2xl flex items-center justify-center mb-5 shadow-md">
					<svg class="w-7 h-7 text-stone-100" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
					</svg>
				</div>
				<h3 class="text-lg md:text-xl font-semibold mb-3 text-stone-800">Loving Care</h3>
				<p class="text-sm md:text-base text-stone-600">Each dog treated with individual attention and care</p>
			</div>
		</div>

		<section class="bg-stone-50 p-6 md:p-10 rounded-3xl shadow-lg">
			<h2 class="text-2xl md:text-3xl font-bold text-stone-800 text-center mb-10">Our Prices</h2>
			<div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8">
				<div class="bg-gradient-to-br from-emerald-800 to-emerald-900 p-6 md:p-8 rounded-2xl text-center text-stone-100 shadow-lg hover:shadow-xl transition-all duration-300 border border-emerald-700">
					<h3 class="text-lg md:text-xl font-semibold mb-4">Single Walk</h3>
					<p class="text-3xl md:text-4xl font-bold mb-4">£20</p>
					<p class="text-sm md:text-base text-stone-300">One 30-minute walk</p>
				</div>
				<div class="bg-gradient-to-br from-amber-700 to-amber-800 p-6 md:p-8 rounded-2xl text-center text-stone-100 shadow-xl scale-105 md:scale-110 transition-all duration-300 border border-amber-600 ring-2 ring-amber-500">
					<h3 class="text-lg md:text-xl font-semibold mb-4">5-Walk Package</h3>
					<p class="text-3xl md:text-4xl font-bold mb-4">£90</p>
					<p class="text-sm md:text-base text-stone-200">£18 per walk (save 10%)</p>
				</div>
				<div class="bg-gradient-to-br from-emerald-800 to-emerald-900 p-6 md:p-8 rounded-2xl text-center text-stone-100 shadow-lg hover:shadow-xl transition-all duration-300 border border-emerald-700">
					<h3 class="text-lg md:text-xl font-semibold mb-4">Daily Service</h3>
					<p class="text-3xl md:text-4xl font-bold mb-4">£130</p>
					<p class="text-sm md:text-base text-stone-300">Weekday walks</p>
				</div>
			</div>
		</section>
	</main>
</div>
