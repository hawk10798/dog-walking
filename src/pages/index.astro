---
import HomePage from '../components/HomePage.astro';
import TestimonialsSection from '../components/TestimonialsSection.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Layout from '../layouts/Layout.astro';
---

<Layout>
	<Header />
	<HomePage />
	<section class="bg-stone-100">
		<div class="max-w-5xl mx-auto">
			<TestimonialsSection />
		</div>
		<div class="text-center pb-8">
			<a href="/testimonials" class="inline-block px-8 py-3 bg-emerald-800 text-stone-100 font-semibold rounded-xl hover:bg-emerald-700 transition-all duration-300 shadow-lg hover:shadow-xl">
				View All Reviews
			</a>
		</div>
	</section>
	<Footer />
</Layout>
